# Variables de entorno para Proyecto Panini 2026

# Token del bot de Telegram (obtén uno en https://t.me/botfather)
TELEGRAM_TOKEN=your_telegram_token_here

# URL de la aplicación web (para el bot mostrar el enlace)
# Usa http://localhost:5000 en desarrollo
# Usa tu IP local (ej: http://192.168.1.100:5000) si accedes desde otro dispositivo
WEB_URL=http://localhost:5000

# Ruta de la base de datos SQLite
# Por defecto: instance/coleccion.db
DATABASE_PATH=instance/coleccion.db

# Entorno de ejecución (development, testing, production)
ENVIRONMENT=development
